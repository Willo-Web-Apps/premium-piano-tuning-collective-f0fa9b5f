---
---
<header class="fixed top-0 left-0 right-0 z-50" style="background: oklch(0.09 0.005 60 / 0.85); backdrop-filter: blur(16px) saturate(1.2); border-bottom: 1px solid oklch(0.72 0.12 78 / 0.12);">
  <nav class="max-w-6xl mx-auto px-6 sm:px-10 lg:px-16 h-16 flex items-center justify-between">

    <!-- Wordmark -->
    <a href="/" class="font-display font-light tracking-[0.18em] uppercase text-surface-950"
       style="font-size: 1.15rem; letter-spacing: 0.18em; color: oklch(0.88 0.018 75);">
      Clavara
    </a>

    <!-- Nav links -->
    <div class="hidden md:flex items-center gap-8">
      <a href="#mission"
         class="font-body text-xs tracking-[0.12em] uppercase font-medium transition-colors duration-150"
         style="color: oklch(0.72 0.12 78 / 0.7); letter-spacing: 0.12em;"
         onmouseover="this.style.color='oklch(0.72 0.12 78)'"
         onmouseout="this.style.color='oklch(0.72 0.12 78 / 0.7)'">
        Mission
      </a>
      <a href="#services"
         class="font-body text-xs tracking-[0.12em] uppercase font-medium transition-colors duration-150"
         style="color: oklch(0.72 0.12 78 / 0.7); letter-spacing: 0.12em;"
         onmouseover="this.style.color='oklch(0.72 0.12 78)'"
         onmouseout="this.style.color='oklch(0.72 0.12 78 / 0.7)'">
        Services
      </a>
      <a href="#process"
         class="font-body text-xs tracking-[0.12em] uppercase font-medium transition-colors duration-150"
         style="color: oklch(0.72 0.12 78 / 0.7); letter-spacing: 0.12em;"
         onmouseover="this.style.color='oklch(0.72 0.12 78)'"
         onmouseout="this.style.color='oklch(0.72 0.12 78 / 0.7)'">
        Process
      </a>
    </div>

    <!-- CTA -->
    <a href="#contact"
       class="font-body text-xs font-medium tracking-[0.12em] uppercase px-6 py-2.5 transition-all duration-200 hover:opacity-80"
       style="border: 1px solid oklch(0.72 0.12 78 / 0.5); color: oklch(0.72 0.12 78); letter-spacing: 0.12em;">
      Engage
    </a>

  </nav>
</header>

<!-- Spacer so fixed header doesn't overlap content -->
<div class="h-16"></div>

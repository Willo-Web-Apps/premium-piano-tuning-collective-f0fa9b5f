---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Clavara — Concert-Grade Piano Care, Delivered.",
  description = "Clavara deploys RPT-certified master piano technicians to concert halls, performing arts venues, and elite touring artists across America's major metro markets."
} = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#0A0A0A" />
    <title>{title}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Clavara",
      "description": "Concert-grade piano tuning and technical service for concert halls, performing arts venues, and elite touring artists across major U.S. metro markets.",
      "url": "https://premium-piano-tuning-collective.onrender.com",
      "serviceArea": {
        "@type": "Country",
        "name": "United States"
      },
      "areaServed": ["New York", "Los Angeles", "Chicago", "Boston", "San Francisco", "Miami", "Houston"]
    }
    </script>
  </head>
  <body class="min-h-screen flex flex-col font-body antialiased"
        style="background-color: oklch(0.09 0.005 60); color: oklch(0.82 0.018 75);">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>

---
import Base from '../layouts/Base.astro';
---
<Base
  title="Clavara — Concert-Grade Piano Care, Delivered."
  description="Clavara deploys RPT-certified master piano technicians to concert halls, performing arts venues, and elite touring artists across America's major metro markets."
>

  <!-- ═══════════════════════════════════════════════════════════════
       HERO — Opening Night at Carnegie Hall
       ═══════════════════════════════════════════════════════════════ -->
  <section class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden noise-overlay">

    <!-- Layered gradient: deep black with warm amber glow from below-left, cold edge top-right -->
    <div class="absolute inset-0" style="
      background:
        radial-gradient(ellipse 70% 55% at 20% 85%, oklch(0.72 0.12 78 / 0.12) 0%, transparent 65%),
        radial-gradient(ellipse 50% 40% at 80% 10%,  oklch(0.72 0.12 78 / 0.06) 0%, transparent 60%),
        radial-gradient(ellipse 90% 60% at 50% 110%, oklch(0.62 0.10 70 / 0.18) 0%, transparent 55%),
        linear-gradient(170deg, oklch(0.07 0.004 60) 0%, oklch(0.09 0.005 65) 50%, oklch(0.06 0.003 55) 100%);
      mask-image: linear-gradient(to bottom, black 75%, transparent 100%);
    "></div>

    <!-- Subtle dot grid texture -->
    <div class="absolute inset-0 opacity-[0.04]" style="
      background-image: radial-gradient(circle at 1px 1px, oklch(0.72 0.12 78) 1px, transparent 0);
      background-size: 32px 32px;
      mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 40%, transparent 100%);
    "></div>

    <!-- Content -->
    <div class="relative z-10 w-full max-w-6xl mx-auto px-6 sm:px-10 lg:px-16 pt-32 pb-24 flex flex-col items-center text-center">

      <!-- Gold rule — top accent -->
      <div class="animate-fade-in mb-10">
        <div style="width: 48px; height: 1px; background: oklch(0.72 0.12 78); margin: 0 auto;"></div>
        <p class="mt-4 text-xs font-body font-medium tracking-[0.3em] uppercase text-brand-500">
          Est. for the World's Great Stages
        </p>
      </div>

      <!-- Hero headline -->
      <h1 class="font-display font-light text-surface-950 animate-slide-up delay-100 leading-[1.04]"
          style="font-size: clamp(3rem, 8vw, 7rem); letter-spacing: -0.01em; max-width: 16ch;">
        The Standard the World's<br/>
        <em class="not-italic" style="color: oklch(0.72 0.12 78);">Great Stages</em> Demand
      </h1>

      <!-- Hero sub -->
      <p class="mt-8 font-body font-light text-surface-800 animate-slide-up delay-200 max-w-xl leading-relaxed"
         style="font-size: 1.1rem; letter-spacing: 0.01em;">
        Clavara deploys master piano technicians to concert halls and elite venues across America's major metro markets.
      </p>

      <!-- CTA pair -->
      <div class="mt-12 flex flex-col sm:flex-row items-center gap-4 animate-slide-up delay-300">
        <a href="#contact"
           class="inline-block px-9 py-3.5 font-body font-medium text-sm tracking-[0.12em] uppercase transition-all duration-200"
           style="background: oklch(0.72 0.12 78); color: oklch(0.09 0.005 60); letter-spacing: 0.12em;">
          Engage Clavara
        </a>
        <a href="#services"
           class="inline-block px-9 py-3.5 font-body font-light text-sm tracking-[0.12em] uppercase text-surface-800 transition-all duration-200 hover:text-surface-950"
           style="border: 1px solid oklch(0.72 0.12 78 / 0.35); letter-spacing: 0.12em;">
          Our Services
        </a>
      </div>

      <!-- Micro-proof -->
      <div class="mt-16 animate-fade-in delay-400 flex items-center gap-6 text-xs font-body font-light text-surface-800/60 tracking-widest uppercase">
        <span>RPT-Certified Technicians</span>
        <span style="color: oklch(0.72 0.12 78 / 0.5);">◆</span>
        <span>Major U.S. Metros</span>
        <span style="color: oklch(0.72 0.12 78 / 0.5);">◆</span>
        <span>Concert Hall Specialists</span>
      </div>

    </div>

    <!-- Bottom fade into next section -->
    <div class="absolute bottom-0 left-0 right-0 h-32" style="background: linear-gradient(to bottom, transparent, oklch(0.09 0.005 60));"></div>
  </section>

  <!-- Gold hairline rule -->
  <div class="gold-rule mx-auto" style="max-width: 1200px;"></div>


  <!-- ═══════════════════════════════════════════════════════════════
       ORIGIN / MISSION — The Story
       ═══════════════════════════════════════════════════════════════ -->
  <section id="mission" class="relative py-28 lg:py-36 noise-overlay" style="background: oklch(0.09 0.005 60);">
    <div class="max-w-5xl mx-auto px-6 sm:px-10 lg:px-16">

      <!-- Section label -->
      <div class="flex items-center gap-4 mb-14">
        <div style="width: 32px; height: 1px; background: oklch(0.72 0.12 78);"></div>
        <span class="font-body text-xs tracking-[0.25em] uppercase font-medium" style="color: oklch(0.72 0.12 78);">
          Our Mission
        </span>
      </div>

      <!-- Narrative -->
      <div class="grid lg:grid-cols-[1fr_2fr] gap-16 lg:gap-24 items-start">

        <!-- Pull quote -->
        <div class="lg:sticky lg:top-28">
          <blockquote class="font-display text-surface-950 leading-snug"
                      style="font-size: clamp(1.6rem, 3vw, 2.25rem); font-style: italic; font-weight: 300;">
            "Some instruments carry the weight of a city's cultural life on a single evening."
          </blockquote>
          <div class="mt-4 h-px w-12" style="background: oklch(0.72 0.12 78 / 0.6);"></div>
        </div>

        <!-- Body copy -->
        <div class="space-y-7 font-body font-light text-surface-800 leading-relaxed" style="font-size: 1.05rem;">
          <p>
            Clavara was founded on a single conviction: the great concert stages of America deserve
            a caliber of piano care that matches their artistic ambition. Not a local tuner dispatched
            on short notice. Not a retail service center juggling residential clients alongside Carnegie
            Hall prep. A dedicated firm, staffed entirely by Registered Piano Technicians with verifiable
            concert-hall credentials.
          </p>
          <p>
            We operate exclusively in the premium tier — serving symphony orchestras, major performing arts
            centers, touring management teams, and luxury hospitality music programs across New York,
            Los Angeles, Chicago, Boston, San Francisco, Miami, and Houston.
          </p>
          <p>
            Every engagement is managed through a concierge scheduling model. Artist preferences, instrument
            histories, and hall acoustics are documented for every instrument we touch — so the piano that
            greets a soloist on performance night has been prepared with the same intentionality as the
            program itself.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- Gold hairline rule -->
  <div class="gold-rule mx-auto" style="max-width: 1200px;"></div>


  <!-- ═══════════════════════════════════════════════════════════════
       SERVICES — Editorial Roster (no card grids)
       ═══════════════════════════════════════════════════════════════ -->
  <section id="services" class="relative py-28 lg:py-36 noise-overlay" style="background: oklch(0.12 0.006 60);">
    <div class="max-w-5xl mx-auto px-6 sm:px-10 lg:px-16">

      <!-- Section label -->
      <div class="flex items-center gap-4 mb-14">
        <div style="width: 32px; height: 1px; background: oklch(0.72 0.12 78);"></div>
        <span class="font-body text-xs tracking-[0.25em] uppercase font-medium" style="color: oklch(0.72 0.12 78);">
          Our Services
        </span>
      </div>

      <h2 class="font-display font-light text-surface-950 mb-16 leading-tight"
          style="font-size: clamp(2rem, 4vw, 3.25rem); max-width: 22ch;">
        Precision Care for Every Instrument That Matters
      </h2>

      <!-- Service roster -->
      <div class="space-y-0">

        <!-- Service 01 -->
        <div class="group border-t py-10 flex flex-col md:flex-row md:items-start md:gap-16 transition-colors duration-300 hover:border-brand-500/40"
             style="border-color: oklch(0.72 0.12 78 / 0.18);">
          <div class="shrink-0 mb-4 md:mb-0 md:w-16 font-body text-xs tracking-[0.2em] font-medium pt-1"
               style="color: oklch(0.72 0.12 78);">01</div>
          <div class="flex-1">
            <h3 class="font-display text-surface-950 mb-3 font-normal"
                style="font-size: 1.55rem;">Concert Preparation & Tuning</h3>
            <p class="font-body font-light text-surface-800 leading-relaxed max-w-2xl" style="font-size: 0.95rem;">
              Pre-performance preparation tailored to the artist's exacting standards — pitch, regulation,
              voicing, and action adjusted for hall acoustics and the performing pianist's touch weight preferences.
              Available for same-day or multi-day engagements.
            </p>
          </div>
        </div>

        <!-- Service 02 -->
        <div class="group border-t py-10 flex flex-col md:flex-row md:items-start md:gap-16 transition-colors duration-300 hover:border-brand-500/40"
             style="border-color: oklch(0.72 0.12 78 / 0.18);">
          <div class="shrink-0 mb-4 md:mb-0 md:w-16 font-body text-xs tracking-[0.2em] font-medium pt-1"
               style="color: oklch(0.72 0.12 78);">02</div>
          <div class="flex-1">
            <h3 class="font-display text-surface-950 mb-3 font-normal"
                style="font-size: 1.55rem;">Touring Artist Technical Support</h3>
            <p class="font-body font-light text-surface-800 leading-relaxed max-w-2xl" style="font-size: 0.95rem;">
              Coordinated technical coverage across every tour city — a single Clavara point of contact
              manages scheduling, artist preference files, and technician briefings so every instrument
              in every market is prepared consistently.
            </p>
          </div>
        </div>

        <!-- Service 03 -->
        <div class="group border-t py-10 flex flex-col md:flex-row md:items-start md:gap-16 transition-colors duration-300 hover:border-brand-500/40"
             style="border-color: oklch(0.72 0.12 78 / 0.18);">
          <div class="shrink-0 mb-4 md:mb-0 md:w-16 font-body text-xs tracking-[0.2em] font-medium pt-1"
               style="color: oklch(0.72 0.12 78);">03</div>
          <div class="flex-1">
            <h3 class="font-display text-surface-950 mb-3 font-normal"
                style="font-size: 1.55rem;">Retained Venue Care Programs</h3>
            <p class="font-body font-light text-surface-800 leading-relaxed max-w-2xl" style="font-size: 0.95rem;">
              Season-long technical partnerships for concert halls and performing arts centers — scheduled
              maintenance, emergency response, instrument inventory management, and annual action regulation
              and voicing services, billed on a flat retainer.
            </p>
          </div>
        </div>

        <!-- Service 04 -->
        <div class="group border-t border-b py-10 flex flex-col md:flex-row md:items-start md:gap-16 transition-colors duration-300 hover:border-brand-500/40"
             style="border-color: oklch(0.72 0.12 78 / 0.18);">
          <div class="shrink-0 mb-4 md:mb-0 md:w-16 font-body text-xs tracking-[0.2em] font-medium pt-1"
               style="color: oklch(0.72 0.12 78);">04</div>
          <div class="flex-1">
            <h3 class="font-display text-surface-950 mb-3 font-normal"
                style="font-size: 1.55rem;">Recording Studio & Luxury Hospitality</h3>
            <p class="font-body font-light text-surface-800 leading-relaxed max-w-2xl" style="font-size: 0.95rem;">
              Precision preparation for studio sessions where any imperfection is captured on tape, and
              ongoing care programs for luxury hotel lounges, private clubs, and hospitality venues where
              the piano is a statement of quality.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Gold hairline rule -->
  <div class="gold-rule mx-auto" style="max-width: 1200px;"></div>


  <!-- ═══════════════════════════════════════════════════════════════
       VENUES — Trust & Caliber
       ═══════════════════════════════════════════════════════════════ -->
  <section id="venues" class="relative py-28 lg:py-36 noise-overlay" style="background: oklch(0.09 0.005 60);">
    <div class="max-w-5xl mx-auto px-6 sm:px-10 lg:px-16">

      <!-- Section label -->
      <div class="flex items-center gap-4 mb-14">
        <div style="width: 32px; height: 1px; background: oklch(0.72 0.12 78);"></div>
        <span class="font-body text-xs tracking-[0.25em] uppercase font-medium" style="color: oklch(0.72 0.12 78);">
          Where We Work
        </span>
      </div>

      <h2 class="font-display font-light text-surface-950 mb-6 leading-tight"
          style="font-size: clamp(2rem, 4vw, 3.25rem); max-width: 28ch;">
        Trusted by the Halls That Set the Standard
      </h2>

      <p class="font-body font-light text-surface-800 leading-relaxed mb-16 max-w-2xl" style="font-size: 1.05rem;">
        Our technicians serve the same caliber of institution recognized as the defining stages of American
        musical culture — from grand symphonic halls to intimate recital venues of national reputation.
      </p>

      <!-- Metro grid -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-px" style="background: oklch(0.72 0.12 78 / 0.12);">
        {[
          { city: "New York", sub: "Carnegie Hall · Lincoln Center · Metropolitan Opera" },
          { city: "Los Angeles", sub: "Walt Disney Concert Hall · Hollywood Bowl · The Broad Stage" },
          { city: "Chicago", sub: "Symphony Center · Lyric Opera · Harris Theater" },
          { city: "San Francisco", sub: "Davies Symphony Hall · War Memorial Opera · Herbst" },
          { city: "Boston", sub: "Symphony Hall · Jordan Hall · Berklee Performance Center" },
          { city: "Houston & Miami", sub: "Jones Hall · Adrienne Arsht Center · Kravis Center" },
        ].map((m) => (
          <div class="p-8" style="background: oklch(0.09 0.005 60);">
            <p class="font-display text-surface-950 font-normal mb-2" style="font-size: 1.25rem;">{m.city}</p>
            <p class="font-body font-light text-surface-800/70 text-xs leading-relaxed tracking-wide">{m.sub}</p>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- Gold hairline rule -->
  <div class="gold-rule mx-auto" style="max-width: 1200px;"></div>


  <!-- ═══════════════════════════════════════════════════════════════
       HOW WE WORK — Concierge Process
       ═══════════════════════════════════════════════════════════════ -->
  <section id="process" class="relative py-28 lg:py-36 noise-overlay" style="background: oklch(0.12 0.006 60);">
    <div class="max-w-5xl mx-auto px-6 sm:px-10 lg:px-16">

      <!-- Section label -->
      <div class="flex items-center gap-4 mb-14">
        <div style="width: 32px; height: 1px; background: oklch(0.72 0.12 78);"></div>
        <span class="font-body text-xs tracking-[0.25em] uppercase font-medium" style="color: oklch(0.72 0.12 78);">
          The Clavara Process
        </span>
      </div>

      <h2 class="font-display font-light text-surface-950 mb-20 leading-tight"
          style="font-size: clamp(2rem, 4vw, 3.25rem); max-width: 24ch;">
        White-Glove Care, From First Contact to Final Note
      </h2>

      <!-- Process steps — vertical timeline with gold accent line -->
      <div class="relative">
        <!-- Vertical gold line -->
        <div class="absolute left-4 top-2 bottom-2 w-px hidden md:block"
             style="background: linear-gradient(to bottom, oklch(0.72 0.12 78 / 0.5), oklch(0.72 0.12 78 / 0.1));"></div>

        <div class="space-y-16 md:space-y-20">

          <div class="md:pl-20 relative">
            <div class="hidden md:flex absolute left-0 top-1 w-8 h-8 items-center justify-center"
                 style="border: 1px solid oklch(0.72 0.12 78 / 0.5); background: oklch(0.12 0.006 60);">
              <span class="font-body text-xs font-medium" style="color: oklch(0.72 0.12 78);">I</span>
            </div>
            <h3 class="font-display text-surface-950 mb-3 font-normal" style="font-size: 1.45rem;">
              Dedicated Account Introduction
            </h3>
            <p class="font-body font-light text-surface-800 leading-relaxed max-w-xl" style="font-size: 0.95rem;">
              Your engagement begins with a consultation — not a web form. A Clavara relationship manager
              documents your venue's inventory, seasonal schedule, resident artist roster, and any
              existing instrument service history.
            </p>
          </div>

          <div class="md:pl-20 relative">
            <div class="hidden md:flex absolute left-0 top-1 w-8 h-8 items-center justify-center"
                 style="border: 1px solid oklch(0.72 0.12 78 / 0.5); background: oklch(0.12 0.006 60);">
              <span class="font-body text-xs font-medium" style="color: oklch(0.72 0.12 78);">II</span>
            </div>
            <h3 class="font-display text-surface-950 mb-3 font-normal" style="font-size: 1.45rem;">
              Artist Preference Documentation
            </h3>
            <p class="font-body font-light text-surface-800 leading-relaxed max-w-xl" style="font-size: 0.95rem;">
              For every touring soloist or resident artist, we maintain a preference file — touch weight,
              voicing tone, pitch reference, pedal regulation — so every instrument prepared for them
              reflects their known requirements precisely.
            </p>
          </div>

          <div class="md:pl-20 relative">
            <div class="hidden md:flex absolute left-0 top-1 w-8 h-8 items-center justify-center"
                 style="border: 1px solid oklch(0.72 0.12 78 / 0.5); background: oklch(0.12 0.006 60);">
              <span class="font-body text-xs font-medium" style="color: oklch(0.72 0.12 78);">III</span>
            </div>
            <h3 class="font-display text-surface-950 mb-3 font-normal" style="font-size: 1.45rem;">
              Performance-Night Preparation
            </h3>
            <p class="font-body font-light text-surface-800 leading-relaxed max-w-xl" style="font-size: 0.95rem;">
              Our technician arrives in advance of the rehearsal, works in coordination with your
              production team, and remains on-call through the performance — available to address
              any adjustment at a moment's notice.
            </p>
          </div>

          <div class="md:pl-20 relative">
            <div class="hidden md:flex absolute left-0 top-1 w-8 h-8 items-center justify-center"
                 style="border: 1px solid oklch(0.72 0.12 78 / 0.5); background: oklch(0.12 0.006 60);">
              <span class="font-body text-xs font-medium" style="color: oklch(0.72 0.12 78);">IV</span>
            </div>
            <h3 class="font-display text-surface-950 mb-3 font-normal" style="font-size: 1.45rem;">
              Continuous Instrument Record
            </h3>
            <p class="font-body font-light text-surface-800 leading-relaxed max-w-xl" style="font-size: 0.95rem;">
              Every service visit is logged in your instrument's permanent record — pitch history,
              regulation notes, repairs, and technician observations. Over time, this becomes a
              living document of your instrument's care and character.
            </p>
          </div>

        </div>
      </div>

    </div>
  </section>

  <!-- Gold hairline rule -->
  <div class="gold-rule mx-auto" style="max-width: 1200px;"></div>


  <!-- ═══════════════════════════════════════════════════════════════
       CONTACT CTA — Engagement
       ═══════════════════════════════════════════════════════════════ -->
  <section id="contact" class="relative py-32 lg:py-44 overflow-hidden noise-overlay" style="background: oklch(0.09 0.005 60);">

    <!-- Warm glow behind CTA text -->
    <div class="absolute inset-0 pointer-events-none" style="
      background:
        radial-gradient(ellipse 60% 50% at 50% 80%, oklch(0.72 0.12 78 / 0.10) 0%, transparent 70%),
        radial-gradient(ellipse 40% 30% at 50% 95%, oklch(0.62 0.10 70 / 0.14) 0%, transparent 65%);
    "></div>

    <div class="relative z-10 max-w-4xl mx-auto px-6 sm:px-10 lg:px-16 text-center">

      <!-- Section label -->
      <div class="flex items-center justify-center gap-4 mb-12">
        <div style="width: 32px; height: 1px; background: oklch(0.72 0.12 78);"></div>
        <span class="font-body text-xs tracking-[0.25em] uppercase font-medium" style="color: oklch(0.72 0.12 78);">
          Begin the Conversation
        </span>
        <div style="width: 32px; height: 1px; background: oklch(0.72 0.12 78);"></div>
      </div>

      <h2 class="font-display font-light text-surface-950 leading-tight mb-8"
          style="font-size: clamp(2.4rem, 5vw, 4.5rem); max-width: 20ch; margin-left: auto; margin-right: auto;">
        Your Stage Deserves Instruments That Perform
      </h2>

      <p class="font-body font-light text-surface-800 leading-relaxed mb-12 max-w-xl mx-auto" style="font-size: 1.05rem;">
        Clavara accepts a limited number of venue partnerships each season. Contact us to discuss
        your program and learn how we can serve your instruments.
      </p>

      <!-- CTA button -->
      <a href="mailto:engagements@clavaraco.com"
         class="inline-block px-12 py-4 font-body font-medium text-sm tracking-[0.15em] uppercase transition-all duration-300 hover:opacity-90"
         style="background: oklch(0.72 0.12 78); color: oklch(0.09 0.005 60); letter-spacing: 0.15em;">
        Contact Our Team
      </a>

      <p class="mt-5 font-body font-light text-surface-800/40 text-xs tracking-widest uppercase">
        Concierge scheduling available · All major U.S. metros
      </p>

    </div>
  </section>

</Base>
